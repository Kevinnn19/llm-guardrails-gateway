# LLM Guardrails Gateway — Environment Variables
# Copy to .env and fill in your values. Never commit .env to version control.

# Application
APP_NAME="LLM Guardrails Gateway"
APP_VERSION="0.1.0"
DEBUG=false
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# Policy
POLICY_DIR=policies
DEFAULT_POLICY_ID=default

# LLM Provider API Keys
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=sk-...
GOOGLE_API_KEY=...

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434

# Retry
MAX_RETRY_ATTEMPTS=3

# Request limits
MAX_REQUEST_BODY_BYTES=1048576
